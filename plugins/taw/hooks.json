{
  "_comment": "taw-kit-codex hooks. Requires [features].codex_hooks = true. Installed by scripts/install.sh --hooks or TAW_INSTALL_HOOKS=1.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CODEX_HOME:-$HOME/.codex}/plugins/taw/hooks/session-start-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|Edit|Write|ApplyPatch|apply_patch|local_shell|exec_command)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CODEX_HOME:-$HOME/.codex}/plugins/taw/hooks/post-tool-auto-commit.sh",
            "timeout": 10,
            "statusMessage": "taw-kit auto-commit checkpoint"
          }
        ]
      }
    ]
  }
}
